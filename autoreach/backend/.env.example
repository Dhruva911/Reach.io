# AutoReach Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autoreach

# ============================================
# REDIS (for BullMQ job queues)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTH
# ============================================
JWT_SECRET=change-this-to-a-random-64-char-string
FRONTEND_URL=http://localhost:3000

# ============================================
# AI — Claude API (Anthropic)
# Leave blank to use mock responses
# ============================================
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================
# PROSPECT DISCOVERY
# ============================================
APOLLO_API_KEY=
CLAY_API_KEY=

# ============================================
# EMAIL DELIVERY
# ============================================
INSTANTLY_API_KEY=
SENDGRID_API_KEY=

# ============================================
# LINKEDIN AUTOMATION
# ============================================
PHANTOMBUSTER_API_KEY=

# ============================================
# WHATSAPP (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================
# APP CONFIG
# ============================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
