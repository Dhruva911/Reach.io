{
  "name": "autoreach-backend",
  "version": "1.0.0",
  "description": "AutoReach — AI-Powered Multi-Channel Outreach Platform API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql",
    "seed": "psql $DATABASE_URL -f seeds/001_auriga_seed.sql",
    "reset-db": "npm run migrate && npm run seed",
    "worker": "node src/jobs/worker.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pg-pool": "^3.6.1",
    "redis": "^4.6.12",
    "bullmq": "^5.1.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "uuid": "^9.0.0",
    "node-cron": "^3.0.3",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0"
  }
}
